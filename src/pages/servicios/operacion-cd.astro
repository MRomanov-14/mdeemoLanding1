---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Operación Logística CD | CLICK Logística" description="Operación integral del centro de distribución en modalidad in house.">
    <section class="py-32 bg-[var(--color-bg)] relative overflow-hidden min-h-screen">
        <div class="absolute top-0 right-0 w-2/3 h-full bg-brand-primary/5 opacity-50 blur-[120px] pointer-events-none"></div>
        <div class="max-w-7xl mx-auto px-6 relative z-10">
            <a href="/servicios" class="inline-flex items-center gap-2 text-[var(--color-text-muted)] hover:text-brand-primary transition-colors mb-12">
                <i class="fa-solid fa-arrow-left"></i> Volver a Servicios
            </a>
            
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div class="space-y-8">
                    <div class="inline-flex items-center justify-center w-20 h-20 bg-brand-primary/10 rounded-2xl text-brand-primary mb-2 shadow-lg">
                        <i class="fa-solid fa-warehouse text-4xl"></i>
                    </div>
                    <h1 class="text-5xl md:text-7xl font-black text-[var(--color-text)] leading-tight font-[Outfit]">
                        OPERACIÓN LOGÍSTICA <br/><span class="text-brand-primary">DE C.D.</span>
                    </h1>
                    <p class="text-xl text-[var(--color-text-muted)] leading-relaxed">
                        Operación integral del centro de distribución en modalidad in house. Concentre sus esfuerzos en generar valor esencial para conseguir una ventaja competitiva.
                    </p>
                    
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 pt-4">
                        <div class="flex items-center gap-3 p-3 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl">
                            <i class="fa-solid fa-shield-halved text-brand-primary text-xl"></i>
                            <span class="text-sm font-medium">Prevenir Riesgos</span>
                        </div>
                        <div class="flex items-center gap-3 p-3 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl">
                            <i class="fa-solid fa-sliders text-brand-primary text-xl"></i>
                            <span class="text-sm font-medium">Ajuste Procesos</span>
                        </div>
                        <div class="flex items-center gap-3 p-3 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl">
                            <i class="fa-solid fa-arrow-trend-down text-brand-primary text-xl"></i>
                            <span class="text-sm font-medium">Reducir Costos</span>
                        </div>
                        <div class="flex items-center gap-3 p-3 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl">
                            <i class="fa-solid fa-lock text-brand-primary text-xl"></i>
                            <span class="text-sm font-medium">Control Total</span>
                        </div>
                        <div class="flex items-center gap-3 p-3 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl">
                            <i class="fa-solid fa-chart-line text-brand-primary text-xl"></i>
                            <span class="text-sm font-medium">Mejorar KPIs</span>
                        </div>
                    </div>
                    
                    <div class="pt-8">
                        <a href="/empresas#solicitud" class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-brand-primary text-black rounded-xl font-bold text-lg hover:bg-yellow-400 transition-all shadow-[0_4px_20px_rgba(234,179,8,0.3)] hover:shadow-[0_4px_30px_rgba(234,179,8,0.5)] transform hover:-translate-y-1 w-full sm:w-auto">
                            Solicitar Cotización <i class="fa-solid fa-file-invoice"></i>
                        </a>
                    </div>
                </div>
                
                <div class="relative rounded-3xl overflow-hidden border border-[var(--color-border)] shadow-2xl group">
                    <div class="absolute inset-0 bg-brand-primary/10 group-hover:bg-transparent transition-colors duration-500 z-10 w-full h-full pointer-events-none"></div>
                    <img src="https://images.unsplash.com/photo-1586528116311-ad8ed7c1590a?q=80&w=1000&auto=format&fit=crop" alt="Operación de Centro de Distribución" class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-700" />
                </div>
            </div>
        </div>
    </section>
</Layout>
