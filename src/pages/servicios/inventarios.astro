---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Toma Física de Inventarios | CLICK Logística" description="Ofrecemos el servicio integral a la medida de la toma física de inventarios de materiales, partes y producto terminado.">
    <section class="py-32 bg-[var(--color-bg)] relative overflow-hidden min-h-screen">
        <div class="absolute top-0 right-0 w-2/3 h-full bg-brand-primary/5 opacity-50 blur-[120px] pointer-events-none"></div>
        <div class="max-w-7xl mx-auto px-6 relative z-10">
            <a href="/servicios" class="inline-flex items-center gap-2 text-[var(--color-text-muted)] hover:text-brand-primary transition-colors mb-12">
                <i class="fa-solid fa-arrow-left"></i> Volver a Servicios
            </a>
            
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div class="space-y-8">
                    <div class="inline-flex items-center justify-center w-20 h-20 bg-brand-primary/10 rounded-2xl text-brand-primary mb-2 shadow-lg">
                        <i class="fa-solid fa-clipboard-check text-4xl"></i>
                    </div>
                    <h1 class="text-5xl md:text-7xl font-black text-[var(--color-text)] leading-tight font-[Outfit]">
                        TOMA FÍSICA <br/>DE <span class="text-brand-primary">INVENTARIOS</span>
                    </h1>
                    <p class="text-xl text-[var(--color-text-muted)] leading-relaxed">
                        Ofrecemos el servicio integral a la medida de la toma física de inventarios de materiales, partes y producto terminado. Optimice sus resultados financieros con métodos productivos y confiables.
                    </p>
                    <div class="flex flex-wrap gap-3 pt-4">
                        <span class="px-5 py-2 text-sm font-semibold bg-[var(--color-surface)] border border-[var(--color-border)] text-brand-primary rounded-full shadow-md">Materiales</span>
                        <span class="px-5 py-2 text-sm font-semibold bg-[var(--color-surface)] border border-[var(--color-border)] text-brand-primary rounded-full shadow-md">Producto Terminado</span>
                        <span class="px-5 py-2 text-sm font-semibold bg-[var(--color-surface)] border border-[var(--color-border)] text-brand-primary rounded-full shadow-md">Partes</span>
                    </div>
                    
                    <div class="pt-8 mb-4 border-t border-[var(--color-border)]">
                        <h3 class="text-2xl font-bold mb-6">Beneficios Clave</h3>
                        <ul class="space-y-4">
                            <li class="flex items-start gap-4">
                                <i class="fa-solid fa-check text-brand-primary mt-1"></i>
                                <span class="text-[var(--color-text-muted)]">Mayor precisión en los registros contables y de existencias físicas.</span>
                            </li>
                            <li class="flex items-start gap-4">
                                <i class="fa-solid fa-check text-brand-primary mt-1"></i>
                                <span class="text-[var(--color-text-muted)]">Detección oportuna de mermas, pérdidas o robos de mercancía.</span>
                            </li>
                            <li class="flex items-start gap-4">
                                <i class="fa-solid fa-check text-brand-primary mt-1"></i>
                                <span class="text-[var(--color-text-muted)]">Cumplimiento de auditorías internas y externas con la máxima rigurosidad.</span>
                            </li>
                        </ul>
                    </div>
                    
                    <div class="pt-8">
                        <a href="/empresas#solicitud" class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-brand-primary text-black rounded-xl font-bold text-lg hover:bg-yellow-400 transition-all shadow-[0_4px_20px_rgba(234,179,8,0.3)] hover:shadow-[0_4px_30px_rgba(234,179,8,0.5)] transform hover:-translate-y-1 w-full sm:w-auto">
                            Solicitar Cotización <i class="fa-solid fa-file-invoice"></i>
                        </a>
                    </div>
                </div>
                
                <div class="relative rounded-3xl overflow-hidden border border-[var(--color-border)] shadow-2xl group">
                    <div class="absolute inset-0 bg-brand-primary/10 group-hover:bg-transparent transition-colors duration-500 z-10 w-full h-full pointer-events-none"></div>
                    <img src="https://images.unsplash.com/photo-1553413077-190dd305871c?q=80&w=1000&auto=format&fit=crop" alt="Toma física de inventarios" class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-700" />
                </div>
            </div>
        </div>
    </section>
</Layout>
