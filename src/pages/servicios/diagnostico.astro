---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Diagnóstico Express CD | CLICK Logística" description="Evaluar, revisar y calificar las operaciones logísticas de los centros de distribución.">
    <section class="py-32 bg-[var(--color-bg)] relative overflow-hidden min-h-screen">
        <div class="absolute top-0 right-0 w-2/3 h-full bg-brand-primary/5 opacity-50 blur-[120px] pointer-events-none"></div>
        <div class="max-w-7xl mx-auto px-6 relative z-10">
            <a href="/servicios" class="inline-flex items-center gap-2 text-[var(--color-text-muted)] hover:text-brand-primary transition-colors mb-12">
                <i class="fa-solid fa-arrow-left"></i> Volver a Servicios
            </a>
            
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div class="space-y-8">
                    <div class="inline-flex items-center justify-center w-20 h-20 bg-brand-primary/10 rounded-2xl text-brand-primary mb-2 shadow-lg">
                        <i class="fa-solid fa-magnifying-glass-chart text-4xl"></i>
                    </div>
                    <h1 class="text-5xl md:text-7xl font-black text-[var(--color-text)] leading-tight font-[Outfit]">
                        DIAGNÓSTICO EXPRESS <br/><span class="text-brand-primary">DE C.D.</span>
                    </h1>
                    <p class="text-xl text-[var(--color-text-muted)] leading-relaxed">
                        Evaluamos, revisamos y calificamos las operaciones logísticas de sus centros de distribución en tiempo récord, identificando los riesgos ocultos que afectan la rentabilidad y productividad.
                    </p>
                    
                    <div class="pt-8">
                        <h3 class="text-2xl font-bold mb-6">Nuestra Metodología Express</h3>
                        <div class="grid gap-4">
                            <div class="flex items-center gap-6 p-6 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl shadow-sm">
                                <div class="text-4xl font-black text-brand-primary/20">01</div>
                                <div>
                                    <h4 class="text-lg font-bold text-[var(--color-text)]">Visita Técnica</h4>
                                    <p class="text-sm text-[var(--color-text-muted)] mt-1">Relevamiento de la operación en sitio con personal especializado.</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-6 p-6 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl shadow-sm">
                                <div class="text-4xl font-black text-brand-primary/20">02</div>
                                <div>
                                    <h4 class="text-lg font-bold text-[var(--color-text)]">Calificación</h4>
                                    <p class="text-sm text-[var(--color-text-muted)] mt-1">Análisis de la información recopilada contrastada con KPIs internacionales.</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-6 p-6 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl shadow-sm">
                                <div class="text-4xl font-black text-brand-primary/20">03</div>
                                <div>
                                    <h4 class="text-lg font-bold text-[var(--color-text)]">Informe</h4>
                                    <p class="text-sm text-[var(--color-text-muted)] mt-1">Presentación ejecutiva de hallazgos, diagnóstico y oportunidades de mejora.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="pt-8">
                        <a href="/empresas#solicitud" class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-brand-primary text-black rounded-xl font-bold text-lg hover:bg-yellow-400 transition-all shadow-[0_4px_20px_rgba(234,179,8,0.3)] hover:shadow-[0_4px_30px_rgba(234,179,8,0.5)] transform hover:-translate-y-1 w-full sm:w-auto">
                            Solicitar Cotización <i class="fa-solid fa-file-invoice"></i>
                        </a>
                    </div>
                </div>
                
                <div class="relative rounded-3xl overflow-hidden border border-[var(--color-border)] shadow-2xl group">
                    <div class="absolute inset-0 bg-brand-primary/10 group-hover:bg-transparent transition-colors duration-500 z-10 w-full h-full pointer-events-none"></div>
                    <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?q=80&w=1000&auto=format&fit=crop" alt="Diagnóstico Express de Centro de Distribución" class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-700" />
                </div>
            </div>
        </div>
    </section>
</Layout>
