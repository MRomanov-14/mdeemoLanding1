---
import Layout from "../../layouts/Layout.astro";
---

<Layout
    title="Servicio de Posicionamiento | CLICK Logística"
    description="Potenciamos su operación integrando personal altamente capacitado garantizando agilidad y excelencia."
>
    <!-- HERO SECTION -->
    <section
        class="relative min-h-[85vh] flex items-center pt-24 pb-16 overflow-hidden bg-[var(--color-bg)]"
    >
        <div class="max-w-7xl mx-auto px-6 relative z-10 w-full">
            <a
                href="/servicios"
                class="inline-flex items-center gap-2 text-[var(--color-text-muted)] hover:text-brand-primary transition-colors mb-10 group bg-[var(--color-surface)] px-5 py-2.5 rounded-full border border-[var(--color-border)] shadow-sm w-fit mt-8"
            >
                <i
                    class="fa-solid fa-arrow-left group-hover:-translate-x-1 transition-transform"
                ></i> Volver a Servicios
            </a>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <!-- Left Content -->
                <div class="max-w-xl">
                    <div
                        class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-brand-primary/10 border border-brand-primary/30 text-brand-primary font-semibold mb-8 shadow-[0_0_20px_rgba(234,179,8,0.15)]"
                    >
                        <span
                            class="w-2.5 h-2.5 rounded-full bg-brand-primary animate-pulse"
                        ></span>
                        Talento de Élite a tu Disposición
                    </div>

                    <h1
                        class="text-6xl md:text-7xl lg:text-[5.5rem] font-black text-[var(--color-text)] leading-[1.1] font-[Outfit] mb-8 tracking-tight"
                    >
                        <span
                            class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-yellow-600"
                            >POSICIONA</span
                        ><br />TU OPERACIÓN
                    </h1>

                    <p
                        class="text-xl md:text-2xl text-[var(--color-text-muted)] leading-relaxed font-light mb-12"
                    >
                        Desplegamos equipos a la medida de tu operación.
                        Garantizamos productividad, agilidad y excelencia desde
                        el primer minuto en tu cadena logística.
                    </p>

                    <div class="flex flex-col sm:flex-row gap-5">
                        <a
                            href="/empresas#solicitud"
                            class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-brand-primary text-black rounded-full font-bold text-lg hover:bg-yellow-400 transition-all shadow-[0_4px_20px_rgba(234,179,8,0.3)] hover:shadow-[0_4px_30px_rgba(234,179,8,0.5)] transform hover:-translate-y-1"
                        >
                            Solicitar Cotización <i
                                class="fa-solid fa-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <!-- Right Image -->
                <div class="relative w-full mx-auto lg:max-w-none">
                    <!-- Glow effect behind image -->
                    <div
                        class="absolute inset-0 bg-brand-primary/20 blur-[80px] rounded-full scale-90 -z-10"
                    >
                    </div>

                    <!-- Image Card -->
                    <div
                        class="relative rounded-[2.5rem] overflow-hidden border border-[var(--color-border)] shadow-2xl aspect-square lg:aspect-[4/5] xl:aspect-square"
                    >
                        <img
                            src="/images/posicionamiento-auxiliares.png"
                            alt="Posicionamiento Operativo"
                            class="w-full h-full object-cover object-center transform hover:scale-105 transition-transform duration-700"
                        />
                        <!-- Subtle inner gradient for polish -->
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg)]/80 via-transparent to-transparent pointer-events-none"
                        >
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ESPECIALIDADES SECTION -->
    <section
        class="py-32 bg-[var(--color-bg)] relative border-b border-[var(--color-border)]"
    >
        <div class="max-w-7xl mx-auto px-6 relative z-10">
            <div class="text-center mb-20">
                <h2
                    class="text-4xl md:text-5xl font-black text-[var(--color-text)] font-[Outfit] mb-6 tracking-tight"
                >
                    Perfiles <span class="text-brand-primary"
                        >Especializados</span>
                </h2>
                <p
                    class="text-[var(--color-text-muted)] max-w-2xl mx-auto text-xl font-light"
                >
                    Equipos entrenados, validados y listos para inyectar
                    velocidad a tu almacén o centro de distribución.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                <!-- Card 1 -->
                <div
                    class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-3xl p-8 hover:border-brand-primary/50 transition-colors group relative overflow-hidden shadow-lg"
                >
                    <div
                        class="absolute -top-10 -right-10 w-40 h-40 bg-brand-primary/5 rounded-full blur-[40px] group-hover:bg-brand-primary/20 transition-colors duration-500 pointer-events-none"
                    >
                    </div>
                    <div
                        class="w-16 h-16 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-2xl flex items-center justify-center text-brand-primary text-3xl mb-8 shadow-inner group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300"
                    >
                        <i class="fa-solid fa-truck-fast"></i>
                    </div>
                    <h3
                        class="text-2xl font-bold text-[var(--color-text)] mb-4 leading-tight"
                    >
                        Auxiliares Logísticos y de Ruta
                    </h3>
                    <p
                        class="text-[var(--color-text-muted)] leading-relaxed relative z-10"
                    >
                        Personal entrenado para distribución, ruteo y apoyo
                        operativo en campo con altísimos estándares.
                    </p>
                </div>
                <!-- Card 2 -->
                <div
                    class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-3xl p-8 hover:border-brand-primary/50 transition-colors group relative overflow-hidden shadow-lg"
                >
                    <div
                        class="absolute -top-10 -right-10 w-40 h-40 bg-brand-primary/5 rounded-full blur-[40px] group-hover:bg-brand-primary/20 transition-colors duration-500 pointer-events-none"
                    >
                    </div>
                    <div
                        class="w-16 h-16 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-2xl flex items-center justify-center text-brand-primary text-3xl mb-8 shadow-inner group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300"
                    >
                        <i class="fa-solid fa-box-open"></i>
                    </div>
                    <h3
                        class="text-2xl font-bold text-[var(--color-text)] mb-4 leading-tight"
                    >
                        Picking y<br />Packing
                    </h3>
                    <p
                        class="text-[var(--color-text-muted)] leading-relaxed relative z-10"
                    >
                        Especialistas veloces en alistamiento de pedidos,
                        embalaje seguro y control de calidad dinámico.
                    </p>
                </div>
                <!-- Card 3 -->
                <div
                    class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-3xl p-8 hover:border-brand-primary/50 transition-colors group relative overflow-hidden shadow-lg"
                >
                    <div
                        class="absolute -top-10 -right-10 w-40 h-40 bg-brand-primary/5 rounded-full blur-[40px] group-hover:bg-brand-primary/20 transition-colors duration-500 pointer-events-none"
                    >
                    </div>
                    <div
                        class="w-16 h-16 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-2xl flex items-center justify-center text-brand-primary text-3xl mb-8 shadow-inner group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300"
                    >
                        <i class="fa-solid fa-dolly"></i>
                    </div>
                    <h3
                        class="text-2xl font-bold text-[var(--color-text)] mb-4 leading-tight"
                    >
                        Cargue y<br />Descargue
                    </h3>
                    <p
                        class="text-[var(--color-text-muted)] leading-relaxed relative z-10"
                    >
                        Fuerza operativa orientada al manejo seguro de carga y
                        optimización drástica de tiempos en muelle.
                    </p>
                </div>
                <!-- Card 4 -->
                <div
                    class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-3xl p-8 hover:border-brand-primary/50 transition-colors group relative overflow-hidden shadow-lg"
                >
                    <div
                        class="absolute -top-10 -right-10 w-40 h-40 bg-brand-primary/5 rounded-full blur-[40px] group-hover:bg-brand-primary/20 transition-colors duration-500 pointer-events-none"
                    >
                    </div>
                    <div
                        class="w-16 h-16 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-2xl flex items-center justify-center text-brand-primary text-3xl mb-8 shadow-inner group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300"
                    >
                        <i class="fa-solid fa-tags"></i>
                    </div>
                    <h3
                        class="text-2xl font-bold text-[var(--color-text)] mb-4 leading-tight"
                    >
                        Servicios de Maquila
                    </h3>
                    <p
                        class="text-[var(--color-text-muted)] leading-relaxed relative z-10"
                    >
                        Terminados precisos, etiquetado masivo, armado de
                        ofertas promocionales y acondicionamiento.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- EL PROCESO (TIMELINE) SECTION -->
    <section class="py-32 bg-[var(--color-bg)] relative overflow-hidden">
        <!-- Background accents -->
        <div
            class="absolute top-1/2 left-0 w-[500px] h-[500px] -translate-y-1/2 -translate-x-1/2 bg-brand-primary/5 blur-[120px] rounded-full pointer-events-none"
        >
        </div>
        <div
            class="absolute bottom-0 right-0 w-[500px] h-[500px] translate-x-1/3 translate-y-1/3 bg-brand-primary/5 blur-[120px] rounded-full pointer-events-none"
        >
        </div>

        <div class="max-w-7xl mx-auto px-6 relative z-10">
            <h3
                class="text-4xl md:text-5xl font-black mb-20 text-center text-[var(--color-text)] font-[Outfit] tracking-tight"
            >
                El Proceso <span class="text-brand-primary">Paso a Paso</span>
            </h3>

            <!-- Timeline Container -->
            <div
                class="relative space-y-6 md:space-y-12 before:absolute before:inset-0 before:ml-8 md:before:ml-[50%] before:-translate-x-px before:h-full before:w-0.5 before:bg-gradient-to-b before:from-brand-primary before:via-brand-primary/20 before:to-transparent"
            >
                <!-- Step 1 -->
                <div class="relative flex items-center group">
                    <div class="hidden md:block w-1/2 pr-16 text-right">
                        <h4
                            class="text-2xl font-bold text-[var(--color-text)] mb-3"
                        >
                            <span class="text-brand-primary text-sm mr-3"
                                >1.</span
                            >Plataforma OPL
                        </h4>
                        <p
                            class="text-base text-[var(--color-text-muted)] leading-relaxed"
                        >
                            Recepción de requerimientos y despliegue de
                            plataforma para seguimiento diario en tiempo real.
                        </p>
                    </div>
                    <div
                        class="absolute left-0 md:left-1/2 transform md:-translate-x-1/2 flex items-center justify-center w-16 h-16 md:w-20 md:h-20 rounded-full border-4 border-[var(--color-surface)] bg-[var(--color-bg)] group-hover:border-brand-primary shadow-[0_0_20px_rgba(234,179,8,0.2)] z-10 transition-all duration-500"
                    >
                        <div
                            class="absolute inset-0 bg-brand-primary/10 rounded-full group-hover:scale-125 transition-transform duration-500"
                        >
                        </div>
                        <svg
                            class="w-6 h-6 md:w-8 md:h-8 text-brand-primary relative z-20"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.5"
                                d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"
                            ></path>
                            <path
                                class="animate-[pulse_1.5s_infinite]"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 11v6m0 0l-3-3m3 3l3-3"></path>
                        </svg>
                    </div>
                    <div
                        class="w-full ml-[4.5rem] md:ml-0 md:w-1/2 md:pl-16 text-left md:hidden bg-[var(--color-surface)] md:bg-transparent p-6 md:p-0 rounded-2xl border border-[var(--color-border)] md:border-none shadow-md md:shadow-none"
                    >
                        <h4
                            class="text-xl font-bold text-[var(--color-text)] mb-2"
                        >
                            <span class="text-brand-primary text-sm mr-2"
                                >1.</span
                            >Plataforma OPL
                        </h4>
                        <p
                            class="text-sm text-[var(--color-text-muted)] leading-relaxed"
                        >
                            Recepción de requerimientos y despliegue de
                            plataforma para seguimiento diario en tiempo real.
                        </p>
                    </div>
                </div>

                <!-- Step 2 -->
                <div class="relative flex items-center group">
                    <div class="hidden md:block w-1/2 pr-16 text-right"></div>
                    <div
                        class="absolute left-0 md:left-1/2 transform md:-translate-x-1/2 flex items-center justify-center w-16 h-16 md:w-20 md:h-20 rounded-full border-4 border-[var(--color-surface)] bg-[var(--color-bg)] group-hover:border-brand-primary shadow-[0_0_20px_rgba(234,179,8,0.2)] z-10 transition-all duration-500"
                    >
                        <div
                            class="absolute inset-0 bg-brand-primary/10 rounded-full group-hover:scale-125 transition-transform duration-500"
                        >
                        </div>
                        <svg
                            class="w-6 h-6 md:w-8 md:h-8 text-brand-primary relative z-20"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.5"
                                d="M17 20h5V16a3 3 0 00-3-3h-2M9 20H4V16a3 3 0 013-3h2"
                            ></path>
                            <circle
                                cx="12"
                                cy="7"
                                r="4"
                                class="animate-pulse"
                                stroke-width="2"></circle>
                            <path
                                class="animate-[pulse_1.5s_infinite]"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 14v6m-3-3h6"></path>
                        </svg>
                    </div>
                    <div
                        class="w-full ml-[4.5rem] md:ml-[50%] md:pl-16 text-left bg-[var(--color-surface)] md:bg-transparent p-6 md:p-0 rounded-2xl border border-[var(--color-border)] md:border-none shadow-md md:shadow-none"
                    >
                        <h4
                            class="text-xl md:text-2xl font-bold text-[var(--color-text)] mb-3"
                        >
                            <span class="text-brand-primary text-sm mr-3"
                                >2.</span
                            >Reclutamiento Guiado
                        </h4>
                        <p
                            class="text-base text-[var(--color-text-muted)] leading-relaxed"
                        >
                            Reclutamiento guiado y asignación inmediata desde
                            nuestra selecta bolsa de talento activa disponible.
                        </p>
                    </div>
                </div>

                <!-- Step 3 -->
                <div class="relative flex items-center group">
                    <div class="hidden md:block w-1/2 pr-16 text-right">
                        <h4
                            class="text-2xl font-bold text-[var(--color-text)] mb-3"
                        >
                            <span class="text-brand-primary text-sm mr-3"
                                >3.</span
                            >App Clicker
                        </h4>
                        <p
                            class="text-base text-[var(--color-text-muted)] leading-relaxed"
                        >
                            Asignación de aplicación móvil nativa para notificar
                            turnos y roles a los colaboradores de inmediato.
                        </p>
                    </div>
                    <div
                        class="absolute left-0 md:left-1/2 transform md:-translate-x-1/2 flex items-center justify-center w-16 h-16 md:w-20 md:h-20 rounded-full border-4 border-[var(--color-surface)] bg-[var(--color-bg)] group-hover:border-brand-primary shadow-[0_0_20px_rgba(234,179,8,0.2)] z-10 transition-all duration-500"
                    >
                        <div
                            class="absolute inset-0 bg-brand-primary/10 rounded-full group-hover:scale-125 transition-transform duration-500"
                        >
                        </div>
                        <svg
                            class="w-6 h-6 md:w-8 md:h-8 text-brand-primary relative z-20"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <rect
                                x="5"
                                y="2"
                                width="14"
                                height="20"
                                rx="2"
                                stroke-width="1.5"></rect>
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.5"
                                d="M12 18h.01"></path>
                            <circle
                                cx="16"
                                cy="6"
                                r="3"
                                fill="currentColor"
                                class="animate-[ping_2s_infinite]"></circle>
                        </svg>
                    </div>
                    <div
                        class="w-full ml-[4.5rem] md:ml-0 md:w-1/2 md:pl-16 text-left md:hidden bg-[var(--color-surface)] md:bg-transparent p-6 md:p-0 rounded-2xl border border-[var(--color-border)] md:border-none shadow-md md:shadow-none"
                    >
                        <h4
                            class="text-xl font-bold text-[var(--color-text)] mb-2"
                        >
                            <span class="text-brand-primary text-sm mr-2"
                                >3.</span
                            >App Clicker
                        </h4>
                        <p
                            class="text-sm text-[var(--color-text-muted)] leading-relaxed"
                        >
                            Asignación de aplicación móvil para notificar turnos
                            de inmediato a los colaboradores.
                        </p>
                    </div>
                </div>

                <!-- Step 4 -->
                <div class="relative flex items-center group">
                    <div class="hidden md:block w-1/2 pr-16 text-right"></div>
                    <div
                        class="absolute left-0 md:left-1/2 transform md:-translate-x-1/2 flex items-center justify-center w-16 h-16 md:w-20 md:h-20 rounded-full border-4 border-[var(--color-surface)] bg-[var(--color-bg)] group-hover:border-brand-primary shadow-[0_0_20px_rgba(234,179,8,0.2)] z-10 transition-all duration-500"
                    >
                        <div
                            class="absolute inset-0 bg-brand-primary/10 rounded-full group-hover:scale-125 transition-transform duration-500"
                        >
                        </div>
                        <svg
                            class="w-6 h-6 md:w-8 md:h-8 text-brand-primary relative z-20"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                class="animate-[spin_4s_linear_infinite] origin-center"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.5"
                                d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                            ></path>
                            <circle
                                cx="12"
                                cy="12"
                                r="3"
                                stroke-width="1.5"
                                class="animate-pulse"></circle>
                        </svg>
                    </div>
                    <div
                        class="w-full ml-[4.5rem] md:ml-[50%] md:pl-16 text-left bg-[var(--color-surface)] md:bg-transparent p-6 md:p-0 rounded-2xl border border-[var(--color-border)] md:border-none shadow-md md:shadow-none"
                    >
                        <h4
                            class="text-xl md:text-2xl font-bold text-[var(--color-text)] mb-3"
                        >
                            <span class="text-brand-primary text-sm mr-3"
                                >4.</span
                            >Operación Adaptable
                        </h4>
                        <p
                            class="text-base text-[var(--color-text-muted)] leading-relaxed"
                        >
                            Fase de operación táctica bajo demanda a la medida
                            de la necesidad y del estándar operativo esperado.
                        </p>
                    </div>
                </div>

                <!-- Step 5 -->
                <div class="relative flex items-center group">
                    <div class="hidden md:block w-1/2 pr-16 text-right">
                        <h4
                            class="text-2xl font-bold text-[var(--color-text)] mb-3"
                        >
                            <span class="text-brand-primary text-sm mr-3"
                                >5.</span
                            >Mejora Continua
                        </h4>
                        <p
                            class="text-base text-[var(--color-text-muted)] leading-relaxed"
                        >
                            Monitoreo continuo en sitio, recolección analítica
                            de métricas y loops de retroalimentación.
                        </p>
                    </div>
                    <div
                        class="absolute left-0 md:left-1/2 transform md:-translate-x-1/2 flex items-center justify-center w-16 h-16 md:w-20 md:h-20 rounded-full border-4 border-[var(--color-surface)] bg-[var(--color-bg)] group-hover:border-brand-primary shadow-[0_0_20px_rgba(234,179,8,0.2)] z-10 transition-all duration-500"
                    >
                        <div
                            class="absolute inset-0 bg-brand-primary/10 rounded-full group-hover:scale-125 transition-transform duration-500"
                        >
                        </div>
                        <svg
                            class="w-6 h-6 md:w-8 md:h-8 text-brand-primary relative z-20 flex"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <line
                                x1="12"
                                y1="20"
                                x2="12"
                                y2="10"
                                stroke-width="2"
                                stroke-linecap="round"
                                class="animate-[pulse_1s_infinite]"></line>
                            <line
                                x1="18"
                                y1="20"
                                x2="18"
                                y2="4"
                                stroke-width="2"
                                stroke-linecap="round"
                                class="animate-[pulse_1.5s_infinite]"></line>
                            <line
                                x1="6"
                                y1="20"
                                x2="6"
                                y2="14"
                                stroke-width="2"
                                stroke-linecap="round"
                                class="animate-[pulse_2s_infinite]"></line>
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.5"
                                d="M3 21h18"></path>
                        </svg>
                    </div>
                    <div
                        class="w-full ml-[4.5rem] md:ml-0 md:w-1/2 md:pl-16 text-left md:hidden bg-[var(--color-surface)] md:bg-transparent p-6 md:p-0 rounded-2xl border border-[var(--color-border)] md:border-none shadow-md md:shadow-none"
                    >
                        <h4
                            class="text-xl font-bold text-[var(--color-text)] mb-2"
                        >
                            <span class="text-brand-primary text-sm mr-2"
                                >5.</span
                            >Mejora Continua
                        </h4>
                        <p
                            class="text-sm text-[var(--color-text-muted)] leading-relaxed"
                        >
                            Monitoreo continuo en sitio, recolección analítica
                            de métricas y loops de retroalimentación.
                        </p>
                    </div>
