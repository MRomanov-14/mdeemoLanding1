                >
                    <div
                        class="bg-[var(--color-surface)] border border-[var(--color-border)] p-10 md:p-14 rounded-3xl w-full max-w-lg shadow-2xl flex flex-col items-center text-center relative overflow-hidden transform scale-95 transition-transform duration-500"
                        id="success-message-card"
                    >
                        <!-- Decorative glow -->
                        <div
                            class="absolute -top-20 -right-20 w-40 h-40 bg-brand-primary/20 blur-[50px] rounded-full pointer-events-none"
                        >
                        </div>
                        <div
                            class="absolute -bottom-20 -left-20 w-40 h-40 bg-brand-primary/10 blur-[50px] rounded-full pointer-events-none"
                        >
                        </div>

                        <div
                            class="w-24 h-24 bg-gradient-to-br from-brand-primary to-yellow-600 rounded-full flex items-center justify-center mb-8 text-5xl text-black shadow-[0_0_40px_rgba(234,179,8,0.5)] animate-bounce relative z-10 mx-auto"
                        >
                            <i class="fa-solid fa-check"></i>
                        </div>

                        <h3
                            class="text-4xl font-extrabold text-white mb-4 tracking-tight"
                        >
                            ¡Recibido!
                        </h3>

                        <p
                            class="text-[var(--color-text-muted)] text-lg mb-10 leading-relaxed max-w-md mx-auto"
                        >
                            La <strong class="text-brand-primary font-semibold"
                                >Ficha de Caracterización</strong
                            > se ha guardado exitosamente. Ya puedes cerrar esta
                            ventana.
                        </p>

                        <button
                            onclick="location.reload()"
                            class="w-full sm:w-auto px-10 py-4 bg-brand-primary hover:bg-yellow-400 text-black rounded-xl font-bold text-lg transition-all shadow-lg hover:shadow-[0_0_20px_rgba(234,179,8,0.5)] transform hover:-translate-y-1"
                        >
                            Volver al Inicio
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal Cropper -->
        <div
            id="cropper-modal"
            class="hidden fixed inset-0 z-[100] bg-black/90 flex flex-col items-center justify-center p-4"
        >
            <div
                class="bg-[var(--color-surface)] border border-[var(--color-border)] p-6 rounded-2xl w-full max-w-[400px] shadow-2xl flex flex-col items-center relative overflow-hidden"
            >
                <h3 class="text-2xl font-bold text-white mb-6">
                    Ajusta tu foto
                </h3>

                <div
                    class="w-full aspect-square bg-black rounded-xl overflow-hidden mb-6 relative"
                >
                    <img id="cropper-image" class="block max-w-full" />
                </div>

                <div class="w-full mb-8">
                    <label
                        class="text-xs font-bold text-[var(--color-text-muted)] tracking-wider mb-3 block uppercase"
                        >Zoom</label
                    >
                    <input
                        type="range"
                        id="cropper-zoom"
                        class="w-full accent-brand-primary"
                        min="0"
                        max="3"
                        step="0.01"
                        value="0.5"
                    />
                </div>

                <div
                    class="flex flex-col sm:flex-row justify-between w-full gap-4"
                >
                    <button
                        type="button"
                        id="btn-cancel-crop"
                        class="flex-1 py-3 px-4 bg-[var(--color-card-bg)] hover:bg-[var(--color-border)] text-white font-medium rounded-xl transition-colors"
                    >
                        Cancelar
                    </button>
                    <button
                        type="button"
                        id="btn-save-crop"
                        class="flex-1 py-3 px-4 bg-brand-primary hover:bg-yellow-400 text-black font-bold rounded-xl transition-colors shadow-lg shadow-brand-primary/20"
                    >
                        Guardar Foto
                    </button>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    import { createClient } from "@supabase/supabase-js";
    import Cropper from "cropperjs";

    let currentStep = 1;
    const totalSteps = 5;

    const steps = [
        document.getElementById("step-1"),
        document.getElementById("step-2"),
        document.getElementById("step-3"),
        document.getElementById("step-4"),
        document.getElementById("step-5"),
    ];

    const dots = document.querySelectorAll(".step-dot");
    const progressLine = document.getElementById("progress-line");
    const formEl = document.getElementById(
        "caracterizacion-form"
    ) as HTMLFormElement;

    // Gateway elements
    const pinGateway = document.getElementById("pin-gateway");
    const wizardProgressHeader = document.getElementById(
        "wizard-progress-header"
    );
    const gatewayCedula = document.getElementById(
        "gateway-cedula"
    ) as HTMLInputElement;
    const gatewayPin = document.getElementById(
        "gateway-pin"
    ) as HTMLInputElement;
    const btnVerifyPin = document.getElementById(
        "btn-verify-pin"
    ) as HTMLButtonElement;

    const fcCedula = document.getElementById("fc-cedula") as HTMLInputElement;
    const fcNombre = document.getElementById("fc-nombre") as HTMLInputElement;
    const fcCorreo = document.getElementById("fc-correo") as HTMLInputElement;
    const fcTelefono = document.getElementById(
        "fc-telefono"
    ) as HTMLInputElement;

    const STORAGE_KEY = "click_caracterizacion_data";
    const AUTH_KEY = "click_caracterizacion_auth";

    const supabaseUrl =
        import.meta.env.PUBLIC_SUPABASE_URL ||
        import.meta.env.NEXT_PUBLIC_SUPABASE_URL;
    const supabaseKey =
        import.meta.env.PUBLIC_SUPABASE_ANON_KEY ||
        import.meta.env.NEXT_PUBLIC_SUPABASE_ANON_KEY;
    const supabase = createClient(supabaseUrl, supabaseKey);

    // --- Auth Gateway Logic ---
    function enableFormView(
        cedulaVal: string,
        nameVal: string,
        emailVal: string = "",
        phoneVal: string = ""
    ) {
        if (pinGateway) pinGateway.classList.add("hidden");
        if (wizardProgressHeader) {
            wizardProgressHeader.classList.remove("hidden");
            // small delay to allow display block to apply before opacity transition
            setTimeout(
                () => wizardProgressHeader.classList.remove("opacity-0"),
                50
            );
        }
        if (formEl) {
            formEl.classList.remove("hidden");
            setTimeout(() => formEl.classList.remove("opacity-0"), 50);
        }

        // Lock form fields
        if (fcCedula) {
            fcCedula.value = cedulaVal;
            fcCedula.readOnly = true;
            fcCedula.classList.add("opacity-60", "cursor-not-allowed");
        }
        if (fcNombre && nameVal) {
            fcNombre.value = nameVal;
        }
        if (fcCorreo && emailVal) {
            fcCorreo.value = emailVal;
        }
        if (fcTelefono && phoneVal) {
            fcTelefono.value = phoneVal;
        }
    }

    if (btnVerifyPin) {
        btnVerifyPin.addEventListener("click", async () => {
            const cedulaVal = gatewayCedula.value.trim();
            const pinVal = gatewayPin.value.trim();

            if (!cedulaVal || !pinVal) {
                alert("Por favor ingresa tu cédula y el PIN.");
                return;
            }

            const originalBtnHtml = btnVerifyPin.innerHTML;
            btnVerifyPin.innerHTML =
                '<i class="fa-solid fa-spinner fa-spin"></i> Verificando...';
            btnVerifyPin.disabled = true;

            try {
                // Check characters in public candidates table
                const { data, error } = await supabase
                    .schema("clicklandingpublic")
                    .from("candidates")
                    .select("full_name, email, phone")
                    .eq("cedula", cedulaVal)
                    .eq("access_pin", pinVal)
                    .maybeSingle();

                if (error) {
                    throw new Error(error.message || JSON.stringify(error));
                }

                if (!data) {
                    throw new Error(
                        "Credenciales inválidas o candidato no seleccionado."
                    );
                }

                // Check if they already filled the form
                const { data: formExists } = await supabase
                    .schema("clicklandingpublic")
                    .from("caracterizacion_candidatos")
                    .select("id")
                    .eq("cedula", cedulaVal)
                    .maybeSingle();

                if (formExists) {
                    alert(
                        "¡Atención! Ya hemos recibido tu ficha de caracterización anteriormente. Si necesitas corregir algo, por favor contáctanos."
                    );
                    btnVerifyPin.innerHTML = originalBtnHtml;
                    btnVerifyPin.disabled = false;
                    return;
                }

                // Success
                localStorage.setItem(
                    AUTH_KEY,
                    JSON.stringify({
                        cedula: cedulaVal,
                        name: data.full_name,
                        email: data.email,
                        phone: data.phone,
                    })
                );
                enableFormView(
                    cedulaVal,
                    data.full_name,
                    data.email,
                    data.phone
                );
            } catch (err: any) {
                console.error("Gateway Auth Error:", err);
                const errorMsg = err.message || JSON.stringify(err);
                alert(
                    `Error verificando datos: ${errorMsg}\nCédula: ${cedulaVal}\nPor favor intenta nuevamente o contáctanos.`
                );
                btnVerifyPin.innerHTML = originalBtnHtml;
                btnVerifyPin.disabled = false;
            }
        });
    }

    // Auto-login from localstorage auth session
    const authSaved = localStorage.getItem(AUTH_KEY);
    if (authSaved) {
        try {
            const parsedAuth = JSON.parse(authSaved);
            if (parsedAuth.cedula) {
                enableFormView(
                    parsedAuth.cedula,
                    parsedAuth.name,
                    parsedAuth.email,
                    parsedAuth.phone
                );
            }
        } catch (e) {
            console.error("Auth parse error", e);
        }
    }

    // --- CropperJS Logic ---
    let cropper: any = null;
    let croppedBlob: Blob | null = null;
    const inputFoto = document.getElementById(
        "input-foto-perfil"
    ) as HTMLInputElement;
    const cropperModal = document.getElementById("cropper-modal");
    const cropperImage = document.getElementById(
        "cropper-image"
    ) as HTMLImageElement;
    const zoomSlider = document.getElementById(
        "cropper-zoom"
    ) as HTMLInputElement;
    const btnCancelCrop = document.getElementById("btn-cancel-crop");
    const btnSaveCrop = document.getElementById("btn-save-crop");
    const previewContainer = document.getElementById("foto-preview-container");
    const previewImg = document.getElementById(
        "foto-preview-img"
    ) as HTMLImageElement;

    if (inputFoto && cropperModal) {
        inputFoto.addEventListener("change", (e) => {
            const files = (e.target as HTMLInputElement).files;
            if (files && files.length > 0) {
                const url = URL.createObjectURL(files[0]);
                if (cropperImage) cropperImage.src = url;
                cropperModal.classList.remove("hidden");

                if (zoomSlider) zoomSlider.value = "0";

                if (cropper) {
                    cropper.destroy();
                }

                // Initialize in next frame
                requestAnimationFrame(() => {
                    cropper = new Cropper(cropperImage, {
                        aspectRatio: 1, // Circular mask ensures 1:1 ratio crops perfectly
                        viewMode: 1,
                        dragMode: "move",
                        background: false,
                        autoCropArea: 0.8,
                        guides: false,
                        center: false,
                        highlight: false,
                        cropBoxMovable: false,
                        cropBoxResizable: false,
                        toggleDragModeOnDblclick: false,
                    } as any);
                });
            }
        });

        zoomSlider?.addEventListener("input", (e) => {
            if (cropper) {
                const ratio = parseFloat((e.target as HTMLInputElement).value);
                const imageData = cropper.getImageData();
                cropper.zoomTo(
                    imageData.naturalWidth / imageData.width + ratio
                );
            }
        });

        btnCancelCrop?.addEventListener("click", () => {
            cropperModal.classList.add("hidden");
            if (cropper) cropper.destroy();
            inputFoto.value = "";
            croppedBlob = null;
            if (previewContainer) previewContainer.classList.add("hidden");
        });

        btnSaveCrop?.addEventListener("click", () => {
            if (!cropper) return;
            const canvas = cropper.getCroppedCanvas({
                width: 800,
                height: 800,
                imageSmoothingEnabled: true,
                imageSmoothingQuality: "high",
            });

            canvas.toBlob(
                (blob) => {
                    if (!blob) return;
                    croppedBlob = blob;

                    const objectUrl = URL.createObjectURL(blob);
                    if (previewImg) previewImg.src = objectUrl;
                    if (previewContainer)
                        previewContainer.classList.remove("hidden");

                    cropperModal.classList.add("hidden");
                    cropper!.destroy();
                },
                "image/webp",
                0.8
            );
        });
    }

    // Persistencia LocalStorage
    if (formEl) {
        const saved = localStorage.getItem(STORAGE_KEY);
        if (saved) {
            try {
                const parsed = JSON.parse(saved);
                Object.keys(parsed).forEach((key) => {
                    const el = formEl.elements.namedItem(key) as
                        | HTMLInputElement
                        | HTMLSelectElement;
                    if (el) {
                        el.value = parsed[key];
                    }
                });

                // Disparar eventos para mostrar/ocultar los condicionales "Otros"
                [
                    "tipo_vivienda",
                    "aspectos_culturales",
                    "tiene_hijos",
                    "regimen_afiliacion",
                    "discapacidad",
                ].forEach((name) => {
                    const el = formEl.elements.namedItem(
                        name
                    ) as HTMLSelectElement;
                    if (el && el.value) {
                        el.dispatchEvent(new Event("change"));
                    }
                });

                // Calcular edad si recuperó fecha
                const fn = document.getElementById("fc-fecha-nac");
                if (fn) fn.dispatchEvent(new Event("change"));
            } catch (e) {
                console.error("Error cargando autoguardado", e);
            }
        }

        formEl.addEventListener("input", () => {
            const fd = new FormData(formEl);
            const doc = Object.fromEntries(fd.entries());
            localStorage.setItem(STORAGE_KEY, JSON.stringify(doc));
        });
    }

    function updateWizardUI() {
        // Toggle steps
        steps.forEach((step, idx) => {
            if (!step) return;
            if (idx + 1 === currentStep) {
                step.classList.remove("hidden", "opacity-0");
            } else {
                step.classList.add("hidden", "opacity-0");
            }
        });

        // Toggle dots & line
        dots.forEach((dot) => {
            const stepNum = parseInt(dot.getAttribute("data-step") || "0");
            if (stepNum <= currentStep) {
                dot.classList.add(
                    "bg-brand-primary",
                    "text-black",
                    "border-[var(--color-bg)]"
                );
                dot.classList.remove(
                    "bg-[var(--color-surface)]",
                    "text-[var(--color-text-muted)]",
                    "border-[var(--color-border)]"
                );
            } else {
                dot.classList.add(
                    "bg-[var(--color-surface)]",
                    "text-[var(--color-text-muted)]",
                    "border-[var(--color-border)]"
                );
                dot.classList.remove(
                    "bg-brand-primary",
                    "text-black",
                    "border-[var(--color-bg)]"
                );
            }
        });

        if (progressLine) {
            progressLine.style.width = (currentStep / totalSteps) * 100 + "%";
        }
    }

    // Validation helper
    function validateCurrentStep() {
        const currentEl = steps[currentStep - 1];
        if (!currentEl) return true;
        const inputs = Array.from(
            currentEl.querySelectorAll("input[required], select[required]")
        ) as (HTMLInputElement | HTMLSelectElement)[];

        let valid = true;
        inputs.forEach((inp) => {
            if (!inp.value.trim()) {
                inp.classList.add("border-red-500", "bg-red-500/10");
                inp.classList.remove(
                    "border-[var(--color-border)]",
                    "bg-[var(--color-card-bg)]"
                );
                valid = false;
            } else {
                inp.classList.remove("border-red-500", "bg-red-500/10");
                inp.classList.add(
                    "border-[var(--color-border)]",
                    "bg-[var(--color-card-bg)]"
                );
            }
        });
        return valid;
    }

    // Attach listeners
    document.querySelectorAll("button[data-next]").forEach((btn) => {
        btn.addEventListener("click", () => {
            if (validateCurrentStep()) {
                currentStep = parseInt(btn.getAttribute("data-next") || "1");
                updateWizardUI();
                window.scrollTo(0, 0);
            } else {
                alert(
                    "Por favor completa todos los campos requeridos de este paso."
                );
            }
        });
    });

    document.querySelectorAll("button[data-prev]").forEach((btn) => {
        btn.addEventListener("click", () => {
            currentStep = parseInt(btn.getAttribute("data-prev") || "1");
            updateWizardUI();
            window.scrollTo(0, 0);
        });
    });

    // Age calculation
    const fn = document.getElementById("fc-fecha-nac") as HTMLInputElement;
    const fe = document.getElementById("fc-edad") as HTMLInputElement;
    if (fn && fe) {
        fn.addEventListener("change", () => {
            if (fn.value) {
                const b = new Date(fn.value);
                const t = new Date();
                let a = t.getFullYear() - b.getFullYear();
                const m = t.getMonth() - b.getMonth();
                if (m < 0 || (m === 0 && t.getDate() < b.getDate())) a--;
                fe.value = a.toString();
            }
        });
    }

    // Submit
    const form = document.getElementById("caracterizacion-form");
    if (form) {
        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            if (!validateCurrentStep()) {
                alert("Por favor completa los campos requeridos.");
                return;
            }

            const btn = document.getElementById(
                "btn-submit"
            ) as HTMLButtonElement;
            const original = btn.innerHTML;
            btn.innerHTML =
                '<i class="fa-solid fa-spinner fa-spin"></i> Enviando...';
            btn.disabled = true;

            const fd = new FormData(form as HTMLFormElement);
            const doc: Record<string, any> = Object.fromEntries(fd.entries());

            // Format numbers and booleans
            [
                "edad",
                "estrato",
                "numero_personas_hogar",
                "numero_personas_cargo",
            ].forEach((k) => {
                if (doc[k]) doc[k] = parseInt(doc[k] as string);
            });
            doc.actualmente_estudia = doc.actualmente_estudia === "true";
            doc.tiene_hijos = doc.tiene_hijos === "true";

            try {
                btn.innerHTML =
                    "Subiendo archivos... <i class='fa-solid fa-spinner fa-spin ml-2'></i>";

                const fileFields = [
                    "doc_foto_fondo_blanco",
                    "doc_fotocopia_cedula",
                    "doc_certificado_pensiones",
                    "doc_antecedentes_policia",
                    "doc_antecedentes_judiciales",
                    "doc_antecedentes_procuraduria",
                    "doc_antecedentes_contraloria",
                ];

                for (const field of fileFields) {
                    let file: File | Blob;
                    let fileExt = "pdf";
                    let isValidFile = false;

                    if (field === "doc_foto_fondo_blanco" && croppedBlob) {
                        file = croppedBlob;
                        fileExt = "webp";
                        isValidFile = true;
                    } else {
                        const fileInput = fd.get(field);
                        if (fileInput && (fileInput as File).size > 0) {
                            file = fileInput as File;
                            fileExt =
                                (file as File).name.split(".").pop() || "pdf";
                            isValidFile = true;
                        }
                    }

                    if (isValidFile) {
                        const fileName = `${
                            doc.cedula
                        }/${field}-${Date.now()}.${fileExt}`;

                        const { data, error } = await supabase.storage
                            .from("candidatos_documentos")
                            .upload(fileName, file!, {
                                upsert: true,
                                contentType:
                                    field === "doc_foto_fondo_blanco" &&
                                    croppedBlob
                                        ? "image/webp"
                                        : undefined,
                            });

                        if (error)
                            throw new Error(
                                "Error subiendo " + field + ": " + error.message
                            );

                        const { data: publicUrldata } = supabase.storage
                            .from("candidatos_documentos")
                            .getPublicUrl(fileName);

                        doc[field] = publicUrldata.publicUrl;
                    } else {
                        delete doc[field];
                    }
                }

                btn.innerHTML =
                    "Guardando ficha... <i class='fa-solid fa-spinner fa-spin ml-2'></i>";

                const { error } = await supabase
                    .schema("clicklandingpublic")
                    .from("caracterizacion_candidatos")
                    .insert([doc]);
                if (error) throw error;

                localStorage.removeItem(STORAGE_KEY);
                localStorage.removeItem(AUTH_KEY);

                const msg = document.getElementById("success-message");
                const msgCard = document.getElementById("success-message-card");
                if (msg && msgCard) {
                    msg.classList.remove("hidden");
                    // Trigger reflow for transition
                    void msg.offsetWidth;
                    msg.classList.remove("opacity-0");
                    msg.classList.add("opacity-100");
                    msgCard.classList.remove("scale-95");
                    msgCard.classList.add("scale-100");
                }
            } catch (err: any) {
                console.error(err);
                alert("Error al enviar: " + err.message);
                btn.innerHTML = original;
                btn.disabled = false;
            }
        });
    }
</script>
