---
import Layout from "../layouts/Layout.astro";
import "cropperjs/dist/cropper.css";
---

<Layout
    title="Ficha de Caracterización | CLICK Logística"
    description="Formulario de caracterización para candidatos pre-seleccionados."
>
    <section
        class="pt-32 pb-20 bg-[var(--color-bg)] min-h-screen relative overflow-hidden"
    >
        <div
            class="absolute top-0 right-0 w-2/3 h-full bg-brand-primary/5 opacity-50 blur-[120px] pointer-events-none"
        >
        </div>
        <style>
            /* Hide number input spinners */
            input[type="number"]::-webkit-inner-spin-button,
            input[type="number"]::-webkit-outer-spin-button {
                -webkit-appearance: none;
                margin: 0;
            }
            input[type="number"] {
                -moz-appearance: textfield;
            }

            /* Show Date Picker Icon clearly on Dark Mode */
            input[type="date"]::-webkit-calendar-picker-indicator {
                cursor: pointer;
                filter: invert(1);
                opacity: 0.6;
                transition: opacity 0.2s;
            }
            input[type="date"]::-webkit-calendar-picker-indicator:hover {
                opacity: 1;
            }

            /* Circular Crop Mask */
            .cropper-view-box,
            .cropper-face {
                border-radius: 50%;
            }
            .cropper-line,
            .cropper-point {
                display: none; /* Hide resizing lines for a clean circular look */
            }
        </style>
        <div class="max-w-5xl mx-auto px-4 sm:px-6 relative z-10">
            <div class="text-center mb-16">
                <h1
                    class="text-4xl md:text-5xl font-black text-[var(--color-text)] mb-4 font-[Outfit]"
                >
                    FICHA DE <span class="text-brand-primary"
                        >CARACTERIZACIÓN</span
                    >
                </h1>
            </div>

            <div
                class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-[2rem] shadow-2xl p-6 md:p-12 md:px-14 relative"
            >
                <!-- PIN Gateway -->
                <div
                    id="pin-gateway"
                    class="flex flex-col items-center justify-center py-10 transition-all duration-300"
                >
                    <div
                        class="bg-[var(--color-card-bg)] border border-[var(--color-border)] p-8 rounded-[2rem] w-full max-w-[450px] shadow-2xl flex flex-col items-center relative overflow-hidden"
                    >
                        <div
                            class="w-20 h-20 bg-brand-primary/10 rounded-full flex items-center justify-center mb-6 text-brand-primary text-3xl"
                        >
                            <i class="fa-solid fa-lock"></i>
                        </div>
                        <h3 class="text-2xl font-bold mb-2">Acceso a Ficha</h3>
                        <p
                            class="text-sm text-[var(--color-text-muted)] text-center mb-8"
                        >
                            Por favor ingresa tu cédula y el PIN de 6 dígitos
                            que recibiste para habilitar el formulario.
                        </p>

                        <div class="w-full mb-5">
                            <label
                                class="text-xs font-bold text-[var(--color-text-muted)] tracking-wider mb-2 block uppercase"
                                >Cédula</label
                            >
                            <input
                                type="number"
                                id="gateway-cedula"
                                class="w-full bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] focus:border-brand-primary focus:ring-1 outline-none transition-all"
                                placeholder="Tu número de documento"
                            />
                        </div>

                        <div class="w-full mb-8">
                            <label
                                class="text-xs font-bold text-[var(--color-text-muted)] tracking-wider mb-2 block uppercase"
                                >PIN de Acceso</label
                            >
                            <input
                                type="number"
                                id="gateway-pin"
                                class="w-full bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] focus:border-brand-primary focus:ring-1 outline-none tracking-[0.5em] font-mono text-center text-xl transition-all"
                                placeholder="******"
                            />
                        </div>

                        <button
                            type="button"
                            id="btn-verify-pin"
                            class="w-full py-4 px-4 bg-brand-primary hover:bg-yellow-400 text-black text-lg font-bold rounded-xl transition-all shadow-lg hover:shadow-[0_0_20px_rgba(234,179,8,0.4)]"
                        >
                            Verificar y Entrar <i
                                class="fa-solid fa-arrow-right ml-2 opacity-70"
                            ></i>
                        </button>
                    </div>
                </div>

                <!-- Progress Line -->
                <div
                    id="wizard-progress-header"
                    class="flex items-center justify-between mb-16 relative px-2 md:px-8 hidden opacity-0 transition-opacity duration-500"
                >
                    <div
                        class="absolute left-0 top-1/2 -translate-y-1/2 w-full h-1 bg-[var(--color-card-bg)] rounded-full -z-10"
                    >
                    </div>
                    <div
                        id="progress-line"
                        class="absolute left-0 top-1/2 -translate-y-1/2 h-1 bg-brand-primary rounded-full transition-all duration-500"
                        style="width: 20%"
                    >
                    </div>
                    <div
                        class="step-dot active w-10 h-10 rounded-full bg-brand-primary flex items-center justify-center font-bold text-black border-4 border-[var(--color-bg)] transition-all z-10"
                        data-step="1"
                    >
                        1
                    </div>
                    <div
                        class="step-dot w-10 h-10 rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] flex items-center justify-center font-bold text-[var(--color-text-muted)] transition-all z-10"
                        data-step="2"
                    >
                        2
                    </div>
                    <div
                        class="step-dot w-10 h-10 rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] flex items-center justify-center font-bold text-[var(--color-text-muted)] transition-all z-10"
                        data-step="3"
                    >
                        3
                    </div>
                    <div
                        class="step-dot w-10 h-10 rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] flex items-center justify-center font-bold text-[var(--color-text-muted)] transition-all z-10"
                        data-step="4"
                    >
                        4
                    </div>
                    <div
                        class="step-dot w-10 h-10 rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] flex items-center justify-center font-bold text-[var(--color-text-muted)] transition-all z-10"
                        data-step="5"
                    >
                        5
                    </div>
                </div>

                <form
                    id="caracterizacion-form"
                    class="hidden opacity-0 transition-opacity duration-500"
                >
                    <!-- STEP 1: Datos Personales -->
                    <div class="wizard-step" id="step-1">
                        <h2
                            class="text-2xl font-bold mb-8 pb-4 border-b border-[var(--color-border)]"
                        >
                            1. Datos Personales Básicos
                        </h2>
                        <div
                            class="grid grid-cols-1 md:grid-cols-2 mt-8"
                            style="column-gap: 3.5rem; row-gap: 2.5rem;"
                        >
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Cédula</span
                                ><input
                                    type="number"
                                    required
                                    id="fc-cedula"
                                    name="cedula"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] focus:border-brand-primary focus:ring-1 outline-none"
                                />
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Nombre Completo</span
                                ><input
                                    type="text"
                                    required
                                    id="fc-nombre"
                                    name="nombre"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] focus:border-brand-primary focus:ring-1 outline-none"
                                />
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Correo</span
                                ><input
                                    type="email"
                                    required
                                    id="fc-correo"
                                    name="correo"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] focus:border-brand-primary focus:ring-1 outline-none"
                                />
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Teléfono</span
                                ><input
                                    type="number"
                                    required
                                    id="fc-telefono"
                                    name="telefono_celular"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] focus:border-brand-primary focus:ring-1 outline-none"
                                />
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Fecha Nacimiento</span
                                ><input
                                    type="date"
                                    required
                                    id="fc-fecha-nac"
                                    name="fecha_nacimiento"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] focus:border-brand-primary focus:ring-1 outline-none"
                                />
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Edad</span
                                ><input
                                    type="number"
                                    required
                                    id="fc-edad"
                                    name="edad"
                                    readonly
                                    class="w-full mt-1 bg-black/20 border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text-muted)] outline-none"
                                />
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Lugar de Nacimiento</span
                                ><input
                                    type="text"
                                    required
                                    name="lugar_nacimiento"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] focus:border-brand-primary focus:ring-1 outline-none"
                                />
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Fecha Expedición CC</span
                                ><input
                                    type="date"
                                    required
                                    name="fecha_expedicion_documento"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] focus:border-brand-primary focus:ring-1 outline-none"
                                />
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Lugar Expedición</span
                                ><input
                                    type="text"
                                    required
                                    name="lugar_expedicion"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] focus:border-brand-primary focus:ring-1 outline-none"
                                />
                            </label>

                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Estado Civil</span
                                >
                                <select
                                    required
                                    name="estado_civil"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none"
                                >
                                    <option value="">Selecciona</option><option
                                        value="Soltero">Soltero(a)</option
                                    ><option value="Casado">Casado(a)</option
                                    ><option value="Unión Libre"
                                        >Unión Libre</option
                                    ><option value="Separado"
                                        >Separado(a)</option
                                    ><option value="Viudo">Viudo(a)</option>
                                </select>
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Género</span
                                >
                                <select
                                    required
                                    name="genero"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none"
                                >
                                    <option value="">Selecciona</option><option
                                        value="Masculino">Masculino</option
                                    ><option value="Femenino">Femenino</option
                                    ><option value="No binario"
                                        >No binario</option
                                    ><option value="Otros">Otros</option><option
                                        value="Prefiero no responder"
                                        >Prefiero no responder</option
                                    >
                                </select>
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Orientación Sexual</span
                                >
                                <select
                                    required
                                    name="orientacion_sexual"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none"
                                >
                                    <option value="">Selecciona</option><option
                                        value="Heterosexual"
                                        >Heterosexual</option
                                    ><option value="Homosexual"
                                        >Homosexual</option
                                    ><option value="Pansexual">Pansexual</option
                                    ><option value="LGTBQ+"
                                        >Comunidad LGTBQ+</option
                                    >
                                </select>
                            </label>
                        </div>
                        <div class="mt-8 flex justify-end">
                            <button
                                type="button"
                                data-next="2"
                                class="px-8 py-3 bg-brand-primary hover:bg-yellow-400 text-black font-bold rounded-xl transition-all"
                                >Siguiente <i
                                    class="fa-solid fa-arrow-right ml-2"></i>
                            </button>
                        </div>
                    </div>

                    <!-- STEP 2: Ubicación y Socioeconómico -->
                    <div class="wizard-step hidden opacity-0" id="step-2">
                        <h2
                            class="text-2xl font-bold mb-8 pb-4 border-b border-[var(--color-border)]"
                        >
                            2. Ubicación y Socioeconómico
                        </h2>
                        <div
                            class="grid grid-cols-1 md:grid-cols-2 mt-8"
                            style="column-gap: 3.5rem; row-gap: 2.5rem;"
                        >
                            <label class="block md:col-span-2"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Dirección</span
                                ><input
                                    type="text"
                                    required
                                    name="direccion_residencia"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none"
                                />
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Barrio</span
                                ><input
                                    type="text"
                                    required
                                    name="barrio"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none"
                                />
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Localidad/Comuna</span
                                ><input
                                    type="text"
                                    required
                                    name="localidad_comuna"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none"
                                />
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    ><select
                                        required
                                        name="municipio_ciudad"
                                        class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none appearance-none"
                                    >
                                        <option value="" disabled selected
                                            >Seleccionar...</option
                                        >
                                        <option value="Bogotá">Bogotá</option>
                                        <option value="Medellín"
                                            >Medellín</option
                                        >
                                        <option value="Cali">Cali</option>
                                        <option value="Barranquilla"
                                            >Barranquilla</option
                                        >
                                    </select>
                                </span>
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Departamento</span
                                ><select
                                    required
                                    name="departamento"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none appearance-none"
                                >
                                    <option value="" disabled selected
                                        >Seleccionar...</option
                                    >
                                    <option value="Amazonas">Amazonas</option>
                                    <option value="Antioquia">Antioquia</option>
                                    <option value="Arauca">Arauca</option>
                                    <option value="Atlántico">Atlántico</option>
                                    <option value="Bogotá D.C."
                                        >Bogotá D.C.</option
                                    >
                                    <option value="Bolívar">Bolívar</option>
                                    <option value="Boyacá">Boyacá</option>
                                    <option value="Caldas">Caldas</option>
                                    <option value="Caquetá">Caquetá</option>
                                    <option value="Casanare">Casanare</option>
                                    <option value="Cauca">Cauca</option>
                                    <option value="Cesar">Cesar</option>
                                    <option value="Chocó">Chocó</option>
                                    <option value="Córdoba">Córdoba</option>
                                    <option value="Cundinamarca"
                                        >Cundinamarca</option
                                    >
                                    <option value="Guainía">Guainía</option>
                                    <option value="Guaviare">Guaviare</option>
                                    <option value="Huila">Huila</option>
                                    <option value="La Guajira"
                                        >La Guajira</option
                                    >
                                    <option value="Magdalena">Magdalena</option>
                                    <option value="Meta">Meta</option>
                                    <option value="Nariño">Nariño</option>
                                    <option value="Norte de Santander"
                                        >Norte de Santander</option
                                    >
                                    <option value="Putumayo">Putumayo</option>
                                    <option value="Quindío">Quindío</option>
                                    <option value="Risaralda">Risaralda</option>
                                    <option value="San Andrés y Providencia"
                                        >San Andrés y Providencia</option
                                    >
                                    <option value="Santander">Santander</option>
                                    <option value="Sucre">Sucre</option>
                                    <option value="Tolima">Tolima</option>
                                    <option value="Valle del Cauca"
                                        >Valle del Cauca</option
                                    >
                                    <option value="Vaupés">Vaupés</option>
                                    <option value="Vichada">Vichada</option>
                                </select>
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Estrato</span
                                >
                                <select
                                    required
                                    name="estrato"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none"
                                >
                                    <option value="">Selecciona</option><option
                                        value="1">1</option
                                    ><option value="2">2</option><option
                                        value="3">3</option
                                    ><option value="4">4</option><option
                                        value="5">5</option
                                    ><option value="6">6</option>
                                </select>
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Tipo Vivienda</span
                                >
                                <select
                                    required
                                    name="tipo_vivienda"
                                    onchange="document.getElementById('otroviv').style.display=this.value==='Otros'?'block':'none'"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none"
                                >
                                    <option value="">Selecciona</option><option
                                        value="Propia">Propia</option
                                    ><option value="Arrendamiento"
                                        >Arrendamiento</option
                                    ><option value="Familiar">Familiar</option
                                    ><option value="Otros">Otros</option>
                                </select>
                                <input
                                    type="text"
                                    id="otroviv"
                                    name="tipo_vivienda_otros"
                                    placeholder="¿Cuál?"
                                    class="w-full mt-2 hidden bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none"
                                />
                            </label>

                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Nº Personas en Hogar</span
                                ><input
                                    type="number"
                                    required
                                    name="numero_personas_hogar"
                                    min="1"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none"
                                />
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Nº Personas a Cargo</span
                                ><input
                                    type="number"
                                    required
                                    name="numero_personas_cargo"
                                    min="0"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none"
                                />
                            </label>
                            <label class="block"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Ingreso Mensual Aprox.</span
                                >
                                <select
                                    required
                                    name="ingreso_mensual_familiar"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none"
                                >
                                    <option value="">Selecciona</option><option
                                        value="-1 SMMLV"
                                        >Menos de 1 SMMLV</option
                                    ><option value="1-2 SMMLV"
                                        >1 a 2 SMMLV</option
                                    ><option value="2-3 SMMLV"
                                        >2 a 3 SMMLV</option
                                    ><option value="+3 SMMLV"
                                        >Más de 3 SMMLV</option
                                    >
                                </select>
                            </label>

                            <label class="block md:col-span-2"
                                ><span
                                    class="text-sm font-medium text-brand-primary uppercase"
                                    >Aspectos Culturales</span
                                >
                                <select
                                    required
                                    name="aspectos_culturales"
                                    onchange="document.getElementById('otroasp').style.display=this.value==='Otros'?'block':'none'"
                                    class="w-full mt-1 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none"
                                >
                                    <option value="">Selecciona</option><option
                                        value="Ninguno">Ninguno</option
                                    ><option value="Afrocolombiano"
                                        >Afrocolombiano</option
                                    ><option value="Indígena">Indígena</option
                                    ><option value="Raizal">Raizal</option
                                    ><option value="Rrom">Rrom (Gitano)</option
                                    ><option value="Otros">Otros</option>
                                </select>
                                <input
                                    type="text"
                                    id="otroasp"
                                    name="aspectos_culturales_otros"
                                    placeholder="Indica"
                                    class="w-full mt-2 hidden bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] outline-none"
                                />
                            </label>

                            <!-- Miembros del hogar (simpificado) -->
                            <div
