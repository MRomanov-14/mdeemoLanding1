---
import Layout from '../../layouts/Layout.astro';

// ALCOMEX DATA
const fecha = "11 de marzo del 2026";
const destinatario = "Javier Rodríguez";
const cargo = "Gerente de Operaciones";
const empresa = "ALCOMEX";
const firmante = "Fernando E. Rodas Diazgranados";
const firmantesCargo = "Gerente";
---

<Layout 
  title="Acceso a Cotización | CLICK Logística"
  description="Ingrese su PIN para acceder a su propuesta comercial confidencial."
>
  <!-- SECURITY GATEWAY -->
  <section id="pin-gateway" class="min-h-screen flex items-center justify-center bg-[var(--color-bg)] px-4 py-20 relative z-50">
    <div class="max-w-md w-full bg-[var(--color-surface)] border border-[var(--color-border)] rounded-3xl p-8 relative overflow-hidden shadow-2xl">
        <!-- Decoración -->
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-brand-primary to-transparent opacity-60"></div>
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-brand-primary/10 rounded-full blur-2xl"></div>

        <div class="flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-full bg-brand-primary/10 border border-brand-primary/20 flex items-center justify-center mb-6">
                <i class="fa-solid fa-lock text-brand-primary text-2xl"></i>
            </div>
            
            <h1 class="text-2xl font-bold text-[var(--color-text)] font-[Outfit] mb-2">Acceso a Cotización</h1>
            <p class="text-[var(--color-text-muted)] text-sm mb-8">Por favor ingresa el PIN de 4 dígitos que te fue asignado para ver tu propuesta comercial.</p>

            <div class="w-full mb-6">
                <label for="quote-pin" class="block text-left text-[11px] font-bold text-[var(--color-text-muted)] uppercase tracking-widest mb-2">PIN DE ACCESO</label>
                <input 
                    type="password" 
                    id="quote-pin" 
                    maxlength="4"
                    class="w-full bg-[var(--color-bg)] border border-[var(--color-border)] rounded-xl px-4 py-3 text-[var(--color-text)] focus:border-brand-primary focus:ring-1 focus:ring-brand-primary outline-none transition-all text-center text-2xl tracking-[0.5em] font-mono"
                    placeholder="••••"
                    autocomplete="off"
                />
            </div>

            <button 
                id="btn-verify-pin"
                class="w-full bg-brand-primary hover:bg-yellow-400 text-black font-bold py-3.5 rounded-xl transition-all shadow-[0_4px_15px_rgba(234,179,8,0.2)] hover:shadow-[0_4px_25px_rgba(234,179,8,0.4)] flex items-center justify-center gap-2"
            >
                <i class="fa-solid fa-key"></i>
                Ver Propuesta
            </button>
            <p id="pin-error" class="text-red-500 text-sm mt-4 font-semibold hidden opacity-0 transition-opacity">PIN incorrecto o propuesta no encontrada.</p>
        </div>
    </div>
  </section>

  <!-- CONTENIDO DE COTIZACIÓN (OCULTO POR DEFECTO) -->
  <div id="proposals-container" class="hidden">
      <!-- ==========================================
           PROPUESTA ALCOMEX (PIN: 7766)
           ========================================== -->
      <div id="content-alcomex" class="hidden proposal-block">
          <!-- Hero / Header de Propuesta -->
          <section class="cotiz-hero relative overflow-hidden pt-36 pb-20">
            <!-- Fondo decorativo -->
            <div class="absolute inset-0 pointer-events-none">
              <div class="absolute top-0 left-0 w-2/3 h-full bg-brand-primary/5 blur-[120px]"></div>
              <div class="absolute bottom-0 right-0 w-1/2 h-1/2 bg-brand-primary/8 blur-[100px]"></div>
              <!-- Grid pattern -->
              <div class="absolute inset-0 opacity-[0.03]" style="background-image: repeating-linear-gradient(0deg, #eab308 0px, #eab308 1px, transparent 1px, transparent 60px), repeating-linear-gradient(90deg, #eab308 0px, #eab308 1px, transparent 1px, transparent 60px);"></div>
            </div>

            <div class="max-w-4xl mx-auto px-6 relative z-10">
              <!-- TOP BADGE -->
              <div class="flex items-center gap-3 mb-10">
                <div class="w-14 h-14 bg-brand-primary rounded-2xl flex items-center justify-center text-black font-black text-3xl shadow-[0_0_30px_rgba(234,179,8,0.4)] flex-shrink-0">C</div>
                <div>
                  <p class="text-xs font-bold text-brand-primary uppercase tracking-widest">Click Operaciones Logísticas S.A.S.</p>
                  <p class="text-[var(--color-text-muted)] text-sm">NIT: documento privado · Bogotá, Colombia</p>
                </div>
                <div class="ml-auto hidden sm:block">
                  <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-primary/10 border border-brand-primary/30 text-brand-primary text-xs font-bold uppercase tracking-wider">
                    <span class="w-2 h-2 rounded-full bg-brand-primary animate-pulse"></span>
                    Oferta Vigente hasta Junio 30 2026
                  </span>
                </div>
              </div>

              <!-- Destinatario card -->
              <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl p-6 mb-8 relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-brand-primary to-transparent opacity-60"></div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                  <div>
                    <p class="text-[var(--color-text-muted)] text-xs uppercase tracking-widest mb-1">Para</p>
                    <p class="font-bold text-[var(--color-text)] text-lg">{empresa}</p>
                    <p class="text-[var(--color-text-muted)]">{destinatario}</p>
                    <p class="text-brand-primary text-xs font-semibold">{cargo}</p>
                  </div>
                  <div class="sm:text-right">
                    <p class="text-[var(--color-text-muted)] text-xs uppercase tracking-widest mb-1">Fecha</p>
                    <p class="font-semibold text-[var(--color-text)]">Bogotá, {fecha}</p>
                    <p class="text-[var(--color-text-muted)] text-xs mt-2">Ref: Cotización – Condiciones comerciales</p>
                  </div>
                </div>
              </div>

              <!-- Título principal -->
              <h1 class="text-4xl md:text-6xl font-black text-[var(--color-text)] leading-tight mb-6 font-[Outfit]">
                PROPUESTA<br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#eab308] via-[#fef08a] to-[#eab308]">COMERCIAL</span>
              </h1>
              <p class="text-[var(--color-text-muted)] text-lg leading-relaxed max-w-2xl">
                Estimado <strong class="text-[var(--color-text)]">{destinatario}</strong>, en nombre de <strong class="text-brand-primary">Click Operaciones Logísticas S.A.S.</strong> nos complace presentar nuestra propuesta de servicios de posicionamiento de personal para su operación logística.
              </p>
            </div>
          </section>

          <!-- Descripción del Servicio -->
          <section class="py-16 bg-[var(--color-bg)]">
            <div class="max-w-4xl mx-auto px-6">
              
              <!-- Servicio Principal -->
              <div class="mb-12">
                <div class="flex items-center gap-3 mb-6">
                  <div class="w-10 h-10 rounded-xl bg-brand-primary/10 border border-brand-primary/30 flex items-center justify-center">
                    <i class="fa-solid fa-users text-brand-primary"></i>
                  </div>
                  <h2 class="text-2xl font-bold text-[var(--color-text)] font-[Outfit]">Alcance de los Servicios</h2>
                </div>

                <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl p-6 md:p-8 space-y-4">
                  <p class="text-[var(--color-text)] font-semibold text-lg">
                    Servicio de posicionamiento de personal para <span class="text-brand-primary">auxiliar logístico</span> en operaciones misionales del CEDI y eventos de cargue y descargue de contenedores.
                  </p>
                  <p class="text-[var(--color-text-muted)] leading-relaxed">
                    Estas operaciones se llevarán a cabo en sus CEDIS (<strong class="text-[var(--color-text)]">Zona Franca Aeropuerto – Sede Principal, Parque Empresarial Siberia e Intexzona</strong>) o la ubicación asignada localmente por el cliente, en horario de <strong class="text-[var(--color-text)]">lunes a sábado, jornada diurna</strong>.
                  </p>
                  <div class="pt-4 border-t border-[var(--color-border)] flex items-start gap-4">
                    <div class="w-8 h-8 rounded-lg bg-brand-primary/10 flex items-center justify-center flex-shrink-0 mt-1">
                      <i class="fa-solid fa-calendar-check text-brand-primary text-sm"></i>
                    </div>
                    <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
                      Las solicitudes se realizarán de forma previa basado en una <strong class="text-[var(--color-text)]">planeación compartida</strong> antes de la prestación del servicio, con la finalidad de contar con el recurso idóneo para esta operación y su promesa de entrega.
                    </p>
                  </div>
                </div>
              </div>

              <!-- SEDES KPI Cards -->
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-16">
                {[
                  { icon: "fa-plane-departure", nombre: "Zona Franca Aeropuerto", detalle: "Sede Principal" },
                  { icon: "fa-industry",        nombre: "Parque Empresarial Siberia", detalle: "Sede 2" },
                  { icon: "fa-warehouse",       nombre: "Intexzona",            detalle: "Sede 3" },
                ].map(sede => (
                  <div class="group bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-brand-primary/50 rounded-2xl p-5 flex flex-col items-center text-center transition-all hover:shadow-[0_0_25px_rgba(234,179,8,0.1)] cursor-default">
                    <div class="w-12 h-12 rounded-xl bg-brand-primary/10 flex items-center justify-center mb-3 group-hover:bg-brand-primary group-hover:text-black transition-all">
                      <i class={`fa-solid ${sede.icon} text-brand-primary group-hover:text-black text-lg`}></i>
                    </div>
                    <p class="font-bold text-[var(--color-text)] text-sm leading-tight">{sede.nombre}</p>
                    <p class="text-brand-primary text-xs font-semibold mt-1">{sede.detalle}</p>
                  </div>
                ))}
              </div>

              <!-- Propuesta Económica -->
              <div class="mb-4">
                <div class="flex items-center gap-3 mb-8">
                  <div class="w-10 h-10 rounded-xl bg-brand-primary/10 border border-brand-primary/30 flex items-center justify-center">
                    <i class="fa-solid fa-dollar-sign text-brand-primary"></i>
                  </div>
                  <h2 class="text-2xl font-bold text-[var(--color-text)] font-[Outfit]">Propuesta Económica</h2>
                </div>

                <!-- TABLA PRINCIPAL DE PRECIOS -->
                <div class="space-y-6">

                  <!-- TARJETA: Auxiliar Logístico CEDI -->
                  <div id="item-auxiliar" class="pricing-card bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl overflow-hidden">
                    <div class="bg-gradient-to-r from-brand-primary/10 to-transparent border-b border-[var(--color-border)] px-6 py-4 flex items-center gap-4">
                      <div class="w-10 h-10 rounded-lg bg-brand-primary/20 flex items-center justify-center flex-shrink-0">
                        <i class="fa-solid fa-person-digging text-brand-primary"></i>
                      </div>
                      <div>
                        <h3 class="font-bold text-[var(--color-text)]">Auxiliar Logístico</h3>
                        <p class="text-brand-primary text-xs font-semibold">Operaciones misionales del CEDI</p>
                      </div>
                    </div>
                    <div class="px-6 py-5">
                      <p class="text-[var(--color-text-muted)] text-sm">Personal especializado para operaciones de almacenamiento, clasificación y distribución interna en el CEDI.</p>
                      <p class="text-xs text-[var(--color-text-muted)] mt-3 italic">Tarifa según planeación compartida y volumen de operación.</p>
                    </div>
                  </div>

                  <!-- TARJETA: Contenedor 40 pies -->
                  <div id="item-40pies" class="pricing-card bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl overflow-hidden hover:border-brand-primary/40 transition-all">
                    <div class="bg-gradient-to-r from-brand-primary/10 to-transparent border-b border-[var(--color-border)] px-6 py-4 flex items-center justify-between flex-wrap gap-4">
                      <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-lg bg-brand-primary/20 flex items-center justify-center flex-shrink-0">
                          <i class="fa-solid fa-container-storage text-brand-primary"></i>
                        </div>
                        <div>
                          <h3 class="font-bold text-[var(--color-text)]">Contenedor de 40 pies</h3>
                          <p class="text-brand-primary text-xs font-semibold">Cargue y/o descargue · mercancía seca</p>
                        </div>
                      </div>
                      <div class="price-badge text-right">
                        <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider">Valor por servicio</p>
                        <p class="text-2xl font-black text-brand-primary">$350.000<span class="text-base font-normal">.oo</span></p>
                        <p class="text-xs text-[var(--color-text-muted)]">+ IVA</p>
                      </div>
                    </div>
                    <div class="px-6 py-5">
                      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 text-sm">
                        <div class="spec-item">
                          <i class="fa-solid fa-users text-brand-primary mr-2 text-xs"></i>
                          <span class="text-[var(--color-text-muted)]">Personas: </span>
                          <span class="font-semibold text-[var(--color-text)]">4 máx.</span>
                        </div>
                        <div class="spec-item">
                          <i class="fa-solid fa-cube text-brand-primary mr-2 text-xs"></i>
                          <span class="text-[var(--color-text-muted)]">Capacidad: </span>
                          <span class="font-semibold text-[var(--color-text)]">67.7 m³</span>
                        </div>
                        <div class="spec-item">
                          <i class="fa-solid fa-weight-hanging text-brand-primary mr-2 text-xs"></i>
                          <span class="text-[var(--color-text-muted)]">Peso: </span>
                          <span class="font-semibold text-[var(--color-text)]">32 ton. máx.</span>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- TARJETA: Contenedor 20 pies -->
                  <div id="item-20pies" class="pricing-card bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl overflow-hidden hover:border-brand-primary/40 transition-all">
                    <div class="bg-gradient-to-r from-brand-primary/10 to-transparent border-b border-[var(--color-border)] px-6 py-4 flex items-center justify-between flex-wrap gap-4">
                      <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-lg bg-brand-primary/20 flex items-center justify-center flex-shrink-0">
                          <i class="fa-solid fa-boxes-stacked text-brand-primary"></i>
                        </div>
                        <div>
                          <h3 class="font-bold text-[var(--color-text)]">Contenedor de 20 pies</h3>
                          <p class="text-brand-primary text-xs font-semibold">Cargue y/o descargue · mercancía seca</p>
                        </div>
                      </div>
                      <div class="price-badge text-right">
                        <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider">Valor por servicio</p>
                        <p class="text-2xl font-black text-brand-primary">$270.000<span class="text-base font-normal">.oo</span></p>
                        <p class="text-xs text-[var(--color-text-muted)]">+ IVA</p>
                      </div>
                    </div>
                    <div class="px-6 py-5">
                      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 text-sm">
                        <div class="spec-item">
                          <i class="fa-solid fa-users text-brand-primary mr-2 text-xs"></i>
                          <span class="text-[var(--color-text-muted)]">Personas: </span>
                          <span class="font-semibold text-[var(--color-text)]">3 máx.</span>
                        </div>
                        <div class="spec-item">
                          <i class="fa-solid fa-cube text-brand-primary mr-2 text-xs"></i>
                          <span class="text-[var(--color-text-muted)]">Capacidad: </span>
                          <span class="font-semibold text-[var(--color-text)]">33 m³</span>
                        </div>
                        <div class="spec-item">
                          <i class="fa-solid fa-weight-hanging text-brand-primary mr-2 text-xs"></i>
                          <span class="text-[var(--color-text-muted)]">Peso: </span>
                          <span class="font-semibold text-[var(--color-text)]">24 ton. máx.</span>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- TARJETA: Camión Sencillo -->
                  <div id="item-sencillo" class="pricing-card bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl overflow-hidden hover:border-brand-primary/40 transition-all">
                    <div class="bg-gradient-to-r from-brand-primary/10 to-transparent border-b border-[var(--color-border)] px-6 py-4 flex items-center justify-between flex-wrap gap-4">
                      <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-lg bg-brand-primary/20 flex items-center justify-center flex-shrink-0">
                          <i class="fa-solid fa-truck text-brand-primary"></i>
                        </div>
                        <div>
                          <h3 class="font-bold text-[var(--color-text)]">Camión Sencillo</h3>
                          <p class="text-brand-primary text-xs font-semibold">Cargue y/o descargue · mercancía seca</p>
                        </div>
                      </div>
                      <div class="price-badge text-right">
                        <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider">Valor por servicio</p>
                        <p class="text-2xl font-black text-brand-primary">$240.000<span class="text-base font-normal">.oo</span></p>
                        <p class="text-xs text-[var(--color-text-muted)]">+ IVA</p>
                      </div>
                    </div>
                    <div class="px-6 py-5">
                      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 text-sm">
                        <div class="spec-item">
                          <i class="fa-solid fa-users text-brand-primary mr-2 text-xs"></i>
                          <span class="text-[var(--color-text-muted)]">Personas: </span>
                          <span class="font-semibold text-[var(--color-text)]">2 máx.</span>
                        </div>
                        <div class="spec-item">
                          <i class="fa-solid fa-cube text-brand-primary mr-2 text-xs"></i>
                          <span class="text-[var(--color-text-muted)]">Capacidad: </span>
                          <span class="font-semibold text-[var(--color-text)]">35 m³</span>
                        </div>
                        <div class="spec-item">
                          <i class="fa-solid fa-weight-hanging text-brand-primary mr-2 text-xs"></i>
                          <span class="text-[var(--color-text-muted)]">Peso: </span>
                          <span class="font-semibold text-[var(--color-text)]">10 ton. máx.</span>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- TARJETA: Turbo -->
                  <div id="item-turbo" class="pricing-card bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl overflow-hidden hover:border-brand-primary/40 transition-all">
                    <div class="bg-gradient-to-r from-brand-primary/10 to-transparent border-b border-[var(--color-border)] px-6 py-4 flex items-center justify-between flex-wrap gap-4">
                      <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-lg bg-brand-primary/20 flex items-center justify-center flex-shrink-0">
                          <i class="fa-solid fa-truck-fast text-brand-primary"></i>
                        </div>
                        <div>
                          <h3 class="font-bold text-[var(--color-text)]">Camión Turbo</h3>
                          <p class="text-brand-primary text-xs font-semibold">Cargue y/o descargue · mercancía seca</p>
                        </div>
                      </div>
                      <div class="price-badge text-right">
                        <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider">Valor por servicio</p>
                        <p class="text-2xl font-black text-brand-primary">$200.000<span class="text-base font-normal">.oo</span></p>
                        <p class="text-xs text-[var(--color-text-muted)]">+ IVA</p>
                      </div>
                    </div>
                    <div class="px-6 py-5">
                      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 text-sm">
                        <div class="spec-item">
                          <i class="fa-solid fa-users text-brand-primary mr-2 text-xs"></i>
                          <span class="text-[var(--color-text-muted)]">Personas: </span>
                          <span class="font-semibold text-[var(--color-text)]">2 máx.</span>
                        </div>
                        <div class="spec-item">
                          <i class="fa-solid fa-cube text-brand-primary mr-2 text-xs"></i>
                          <span class="text-[var(--color-text-muted)]">Capacidad: </span>
                          <span class="font-semibold text-[var(--color-text)]">21.5 m³</span>
                        </div>
                        <div class="spec-item">
                          <i class="fa-solid fa-weight-hanging text-brand-primary mr-2 text-xs"></i>
                          <span class="text-[var(--color-text-muted)]">Peso: </span>
                          <span class="font-semibold text-[var(--color-text)]">4.5 – 5 ton.</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </section>

          <!-- Notas y condiciones -->
          <section class="py-16 bg-[var(--color-bg)]">
            <div class="max-w-4xl mx-auto px-6">

              <div class="flex items-center gap-3 mb-8">
                <div class="w-10 h-10 rounded-xl bg-brand-primary/10 border border-brand-primary/30 flex items-center justify-center">
                  <i class="fa-solid fa-circle-info text-brand-primary"></i>
                </div>
                <h2 class="text-2xl font-bold text-[var(--color-text)] font-[Outfit]">Notas y Condiciones</h2>
              </div>

              <div class="space-y-4 mb-12">
                {[
                  {
                    num: "01",
                    txt: "La cantidad de auxiliares para el descargue o cargue está descrita en cada uno de los ítems, en condiciones normales, sin embargo, las excepciones pueden sufrir variaciones (más o menos personas) previa comunicación por parte del cliente frente a los volúmenes y tipo de mercancía, y esto afectaría la tarifa."
                  },
                  {
                    num: "02",
                    txt: "Estos precios tienen vigencia durante la prestación de los servicios en el año 2025; para el próximo año se ajustará el incremento porcentual del salario mínimo que emita el gobierno."
                  },
                  {
                    num: "03",
                    txt: "La factura se enviará de manera electrónica a nombre de ALCOMEX, máximo 5 días después del corte semanal de haber prestado el servicio, para pago a 30 días calendario."
                  }
                ].map(nota => (
                  <div class="flex gap-5 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl p-5">
                    <div class="text-brand-primary font-black text-3xl opacity-30 leading-none select-none flex-shrink-0 font-[Outfit]">{nota.num}</div>
                    <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">{nota.txt}</p>
                  </div>
                ))}
              </div>

              <!-- Protección de Datos y Confidencialidad -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
                <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl p-6">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-9 h-9 rounded-lg bg-brand-primary/10 flex items-center justify-center">
                      <i class="fa-solid fa-shield-halved text-brand-primary text-sm"></i>
                    </div>
                    <h3 class="font-bold text-[var(--color-text)]">Protección de Datos</h3>
                  </div>
                  <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
