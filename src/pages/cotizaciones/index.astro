          <!-- SCRIPT PARA MANEJAR EL ACCESO CON PIN -->
          <script>
            const btnVerify = document.getElementById("btn-verify-pin");
            const pinInput = document.getElementById("quote-pin");
            const errorMsg = document.getElementById("pin-error");

            const pinGateway = document.getElementById("pin-gateway");
            const proposalsContainer = document.getElementById(
              "proposals-container",
            );

            const sessionKey = "quote_access_pin";

            // Diccionario de PINs y sus respectivos contenedores
            const validPinsElementMap: Record<string, string> = {
              "7766": "content-alcomex",
              "8877": "content-geodis",
              "1122": "content-latelier",
              "1123": "content-distri",
              "1124": "content-imbocar",
              "1125": "content-jason",
              "1127": "content-konfie",
            };

            // PINs que abren un overlay full-page con iframe
            const overlayPinsMap: Record<string, string> = {
              "1126": "/cotizaciones/1126.html",
            };

            const unlockProposal = (pin: string) => {
              // Overlay full-page (iframe fuera del Layout)
              if (overlayPinsMap[pin]) {
                const overlay = document.getElementById("overlay-clickdev");
                const iframe = document.getElementById("iframe-clickdev") as HTMLIFrameElement | null;
                if (overlay && iframe) {
                  if (!iframe.src || !iframe.src.includes("1126")) {
                    iframe.src = overlayPinsMap[pin];
                  }
                  overlay.classList.remove("hidden");
                  pinGateway?.classList.add("hidden");
                  sessionStorage.setItem(sessionKey, pin);
                  return true;
                }
              }

              const contentId = validPinsElementMap[pin];
              if (contentId) {
                // Hide gateway
                pinGateway?.classList.add("hidden");

                // Show main container
                proposalsContainer?.classList.remove("hidden");

                // Hide all proposals just in case, then show the specific one
                document
                  .querySelectorAll(".proposal-block")
                  .forEach((el) => el.classList.add("hidden"));
                document.getElementById(contentId)?.classList.remove("hidden");

                // Scroll to top
                window.scrollTo(0, 0);

                // Save to session to avoid re-entering on refresh
                sessionStorage.setItem(sessionKey, pin);
                return true;
              }
              return false;
            };

            // Check session storage on load
            const savedPin = sessionStorage.getItem(sessionKey);
            if (savedPin && validPinsElementMap[savedPin]) {
              unlockProposal(savedPin);
            }

            // Handle button click
            btnVerify?.addEventListener("click", () => {
              const enteredPin = (pinInput as HTMLInputElement).value;

              if (!enteredPin) return;

              btnVerify.innerHTML =
                '<i class="fa-solid fa-spinner fa-spin"></i> Verificando...';
              btnVerify.setAttribute("disabled", "true");

              errorMsg?.classList.add("opacity-0");
              errorMsg?.classList.add("hidden");

              setTimeout(() => {
                const success = unlockProposal(enteredPin);

                if (!success) {
                  errorMsg?.classList.remove("hidden");
                  // Trigger reflow
                  void errorMsg?.offsetWidth;
                  errorMsg?.classList.remove("opacity-0");

                  btnVerify.innerHTML =
                    '<i class="fa-solid fa-key"></i> Ver Propuesta';
                  btnVerify.removeAttribute("disabled");
                }
              }, 800); // Simulate verification delay for UX
            });

            // Handle Enter key
            pinInput?.addEventListener("keypress", (e) => {
              if (e.key === "Enter") {
                btnVerify?.click();
              }
            });

            // PDF Download button (ALCOMEX)
            const btnPdf = document.getElementById("btn-download-pdf");
            btnPdf?.addEventListener("click", () => {
              window.print();
            });

            // PDF Download button (GEODIS)
            const btnPdfGeodis = document.getElementById(
              "btn-download-pdf-geodis",
            );
            btnPdfGeodis?.addEventListener("click", () => {
              window.print();
            });

            const btnPdfGeodisTransporte = document.getElementById(
              "btn-download-pdf-geodis-transporte",
            );
            btnPdfGeodisTransporte?.addEventListener("click", () => {
              window.print();
            });

            // PDF Download button (DISTRI)
            const btnPdfDistri = document.getElementById(
              "btn-download-pdf-distri",
            );
            btnPdfDistri?.addEventListener("click", () => {
              window.print();
            });

            // PDF Download button (IMBOCAR)
            const btnPdfImbocar = document.getElementById(
              "btn-download-pdf-imbocar",
            );
            btnPdfImbocar?.addEventListener("click", () => {
              window.print();
            });

            // PDF Download button (JASON)
            const btnPdfJason = document.getElementById(
              "btn-download-pdf-jason",
            );
            btnPdfJason?.addEventListener("click", () => {
              window.print();
            });

            // === LÓGICA DE FIRMA EN EL CANVAS ===
            const btnSignProposal =
              document.getElementById("btn-sign-proposal");
            const signatureModal = document.getElementById("signature-modal");
            const btnCancelSig = document.getElementById("btn-cancel-sig");
            const btnClearSig = document.getElementById("btn-clear-sig");
            const btnSaveSig = document.getElementById("btn-save-sig");
            const canvas = document.getElementById(
              "signature-pad",
            ) as HTMLCanvasElement | null;

            const signatureContainer = document.getElementById(
              "client-signature-container",
            );
            const signatureImg = document.getElementById(
              "client-signature-img",
            ) as HTMLImageElement | null;

            if (
              canvas &&
              btnSignProposal &&
              signatureModal &&
              btnCancelSig &&
              btnClearSig &&
              btnSaveSig &&
              signatureContainer &&
              signatureImg
            ) {
              const ctx = canvas.getContext("2d");
              let drawing = false;

              function resizeCanvas() {
                if (!canvas) return;
                const parent = canvas.parentElement;
                if (!parent) return;

                const rect = parent.getBoundingClientRect();
                canvas.width = rect.width;
                canvas.height = rect.height || 192; // 48 rem approx
                // Reset styles after resize
                if (ctx) {
                  ctx.strokeStyle = "#eab308";
                  ctx.lineWidth = 3;
                  ctx.lineJoin = "round";
                  ctx.lineCap = "round";
                }
              }

              function getPos(e) {
                const rect = canvas.getBoundingClientRect();
                const clientX = e.touches ? e.touches[0].clientX : e.clientX;
                const clientY = e.touches ? e.touches[0].clientY : e.clientY;
                return {
                  x: clientX - rect.left,
                  y: clientY - rect.top,
                };
              }

              function startDrawing(e) {
                if (!ctx) return;
                e.preventDefault();
                drawing = true;
                const pos = getPos(e);
                ctx.beginPath();
                ctx.moveTo(pos.x, pos.y);
              }

              function draw(e) {
                if (!drawing || !ctx) return;
                e.preventDefault();
                const pos = getPos(e);
                ctx.lineTo(pos.x, pos.y);
                ctx.stroke();
              }

              function stopDrawing() {
                if (!drawing || !ctx) return;
                drawing = false;
                ctx.closePath();
              }

              canvas.addEventListener("mousedown", startDrawing);
              canvas.addEventListener("mousemove", draw);
              canvas.addEventListener("mouseup", stopDrawing);
              canvas.addEventListener("mouseout", stopDrawing);

              canvas.addEventListener("touchstart", startDrawing, {
                passive: false,
              });
              canvas.addEventListener("touchmove", draw, { passive: false });
              canvas.addEventListener("touchend", stopDrawing);
              canvas.addEventListener("touchcancel", stopDrawing);

              // Botón abrir
              btnSignProposal.addEventListener("click", () => {
                signatureModal.style.display = "flex";
                // Pequeño delay para asegurar que el modal se renderizó entes de medirlo
                setTimeout(resizeCanvas, 50);
              });

              // Botón cancelar
              btnCancelSig.addEventListener("click", () => {
                signatureModal.style.display = "none";
              });

              // Botón limpiar
              btnClearSig.addEventListener("click", () => {
                if (ctx && canvas) {
                  ctx.clearRect(0, 0, canvas.width, canvas.height);
                }
              });

              // Botón guardar
              btnSaveSig.addEventListener("click", () => {
                const dataUrl = canvas.toDataURL("image/png");
                signatureImg.src = dataUrl;

                btnSignProposal.style.display = "none";
                signatureContainer.classList.remove("hidden");
                signatureContainer.style.display = "flex";

                signatureModal.style.display = "none";

                // Abrir descarga del documento en modo print (light mode)
                setTimeout(() => {
                  window.print();
                }, 500);
              });

              window.addEventListener("resize", () => {
                if (signatureModal.style.display === "flex") {
                  resizeCanvas();
                }
              });
            }
          </script>

