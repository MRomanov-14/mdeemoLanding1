  <!-- SCRIPT PARA MANEJAR EL ACCESO CON PIN -->
  <script>
    const btnVerify = document.getElementById("btn-verify-pin");
    const pinInput = document.getElementById("quote-pin");
    const errorMsg = document.getElementById("pin-error");

    const pinGateway = document.getElementById("pin-gateway");
    const proposalsContainer = document.getElementById("proposals-container");

    const sessionKey = "quote_access_pin";

    // Diccionario de PINs y sus respectivos contenedores
    const validPinsElementMap: Record<string, string> = {
      "7766": "content-alcomex",
      "8877": "content-geodis",
    };

    const unlockProposal = (pin: string) => {
      const contentId = validPinsElementMap[pin];
      if (contentId) {
        // Hide gateway
        pinGateway?.classList.add("hidden");

        // Show main container
        proposalsContainer?.classList.remove("hidden");

        // Hide all proposals just in case, then show the specific one
        document
          .querySelectorAll(".proposal-block")
          .forEach((el) => el.classList.add("hidden"));
        document.getElementById(contentId)?.classList.remove("hidden");

        // Scroll to top
        window.scrollTo(0, 0);

        // Save to session to avoid re-entering on refresh
        sessionStorage.setItem(sessionKey, pin);
        return true;
      }
      return false;
    };

    // Check session storage on load
    const savedPin = sessionStorage.getItem(sessionKey);
    if (savedPin && validPinsElementMap[savedPin]) {
      unlockProposal(savedPin);
    }

    // Handle button click
    btnVerify?.addEventListener("click", () => {
      const enteredPin = (pinInput as HTMLInputElement).value;

      if (!enteredPin) return;

      btnVerify.innerHTML =
        '<i class="fa-solid fa-spinner fa-spin"></i> Verificando...';
      btnVerify.setAttribute("disabled", "true");

      errorMsg?.classList.add("opacity-0");
      errorMsg?.classList.add("hidden");

      setTimeout(() => {
        const success = unlockProposal(enteredPin);

        if (!success) {
          errorMsg?.classList.remove("hidden");
          // Trigger reflow
          void errorMsg?.offsetWidth;
          errorMsg?.classList.remove("opacity-0");

          btnVerify.innerHTML = '<i class="fa-solid fa-key"></i> Ver Propuesta';
          btnVerify.removeAttribute("disabled");
        }
      }, 800); // Simulate verification delay for UX
    });

    // Handle Enter key
    pinInput?.addEventListener("keypress", (e) => {
      if (e.key === "Enter") {
        btnVerify?.click();
      }
    });

    // PDF Download button (ALCOMEX)
    const btnPdf = document.getElementById("btn-download-pdf");
    btnPdf?.addEventListener("click", () => {
      window.print();
    });

    // PDF Download button (GEODIS)
    const btnPdfGeodis = document.getElementById("btn-download-pdf-geodis");
    btnPdfGeodis?.addEventListener("click", () => {
      window.print();
    });

    const btnPdfGeodisTransporte = document.getElementById(
      "btn-download-pdf-geodis-transporte"
    );
    btnPdfGeodisTransporte?.addEventListener("click", () => {
      window.print();
    });
  </script>

